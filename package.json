{
  "name": "kontinue-ai-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "web",
    "mobile"
  ],
  "dependencies": {
    "convex": "^1.32.0",
    "convex-firecrawl-scrape": "^0.1.3",
    "ai": "^6.0.78",
    "@ai-sdk/gateway": "^3.0.40"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^20.19.22",
    "fast-check": "^4.6.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "bun run dev:web",
    "build": "bun run build:web",
    "test": "bun run test:convex && bun run test:web",
    "dev:web": "bun run --cwd web dev",
    "dev:mobile": "bun run --cwd mobile dev",
    "dev:convex": "./scripts/convex.sh dev",
    "build:web": "bun run --cwd web build",
    "lint:web": "bun run --cwd web lint",
    "lint:mobile": "bun run --cwd mobile lint",
    "lint": "bun run lint:web && bun run lint:mobile",
    "typecheck:web": "bun run --cwd web typecheck",
    "typecheck:mobile": "bun run --cwd mobile typecheck",
    "typecheck:convex": "tsc -p convex/tsconfig.json --noEmit",
    "typecheck": "bun run typecheck:web && bun run typecheck:mobile && bun run typecheck:convex",
    "test:convex": "bun test convex",
    "test:web": "bun run --cwd web test",
    "convex:codegen": "./scripts/convex.sh codegen",
    "convex:deploy": "./scripts/convex.sh deploy"
  }
}
